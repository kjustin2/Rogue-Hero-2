{
  "name": "rogue-hero",
  "version": "1.0.0",
  "description": "A tempo-driven roguelike deck builder",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "test": "node mp-smoke.mjs && node mp-disconnect-test.mjs && node mp-4player-test.mjs",
    "test:mp4": "node mp-4player-test.mjs",
    "test:smoke": "playwright test -c tests/playwright.config.js",
    "test:smoke:headed": "playwright test -c tests/playwright.config.js --headed",
    "test:smoke:ui": "playwright test -c tests/playwright.config.js --ui",
    "serve": "python -m http.server 8000",
    "mp": "node mp-local.mjs",
    "syntax": "node check-syntax.js",
    "dist": "electron-builder --win --publish never",
    "dist:mac": "electron-builder --mac --publish never",
    "dist:linux": "electron-builder --linux --publish never"
  },
  "build": {
    "appId": "com.roguehero.game",
    "productName": "Rogue Hero",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "style.css",
      "manifest.json",
      "src/**/*",
      "imgs/**/*",
      "music/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "imgs/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "imgs/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "imgs/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "imgs/icon.ico",
      "shortcutName": "Rogue Hero"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0"
  }
}
